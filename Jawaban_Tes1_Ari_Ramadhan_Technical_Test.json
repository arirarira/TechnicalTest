  "item": [
    {
      "name": "Post Pendaftaran",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseJson = pm.response.json();",
              "console.log(responseJson);",
              "pm.environment.set(\"technical-test-response\", JSON.stringify(responseJson));",
              "console.log(\"✔ Saved to environment: technical-test-response\");",
              "",
              "const requestBodyData = JSON.parse(pm.request.body);",
              "",
              "// ─── Helpers ────────────────────────────────────────────────────────────────",
              "function formatWithCommas(number) {",
              "    return number.toLocaleString('en-US');",
              "}",
              "",
              "const formatTime = (milliseconds) => {",
              "    const hours   = String(Math.floor(milliseconds / 3600000)).padStart(2, '0');",
              "    const minutes = String(Math.floor((milliseconds % 3600000) / 60000)).padStart(2, '0');",
              "    const seconds = String(Math.floor((milliseconds % 60000) / 1000)).padStart(2, '0');",
              "    const millis  = String(milliseconds % 1000).padStart(3, '0');",
              "    return `${hours}:${minutes}:${seconds}.${millis}`;",
              "};",
              "",
              "// ─── TC-01 : Status Code 200 ─────────────────────────────────────────────────",
              "(() => {",
              "    pm.test(`TC-01 | Validasi Status Code Response Berhasil (200)`, function () {",
              "        pm.response.to.have.status(200);",
              "    });",
              "})();",
              "",
              "// ─── TC-02 : Response Time < 5000 ms ─────────────────────────────────────────",
              "(() => {",
              "    pm.test(`TC-02 | Waktu respons dapat diterima (< 5000 ms) | Aktual: ${formatTime(pm.response.responseTime)}`, function () {",
              "        pm.expect(pm.response.responseTime).to.be.below(5000);",
              "    });",
              "})();",
              "",
              "// ─── TC-03 : Content-Type is application/json ────────────────────────────────",
              "(() => {",
              "    pm.test(`TC-03 | Header Content-Type adalah application/json`, function () {",
              "        pm.response.to.have.header('Content-Type');",
              "        pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "    });",
              "})();",
              "",
              "// ─── TC-04 : Response body is not empty ──────────────────────────────────────",
              "(() => {",
              "    pm.test(`TC-04 | Body response tidak kosong`, function () {",
              "        pm.expect(pm.response.text()).to.not.be.empty;",
              "    });",
              "})();",
              "",
              "// ─── TC-05 : Response body is valid JSON ─────────────────────────────────────",
              "(() => {",
              "    pm.test(`TC-05 | Body response adalah JSON yang valid`, function () {",
              "        pm.response.to.be.json;",
              "    });",
              "})();",
              "",
              "// ─── TC-06 : Successful registration — header.code = 200 ─────────────────────",
              "(() => {",
              "    const code = responseJson.header && responseJson.header.code;",
              "    pm.test(`TC-06 | Pendaftaran berhasil: header.code = 200 | Aktual: ${code}`, function () {",
              "        pm.expect(code).to.eql(200);",
              "    });",
              "})();",
              "",
              "// ─── TC-07 : Validate 'nama' is a non-empty string ───────────────────────────",
              "(() => {",
              "    const nama = requestBodyData.nama;",
              "    pm.test(`TC-07 | Field 'nama' pada request adalah string tidak kosong | Nilai: \"${nama}\"`, function () {",
              "        pm.expect(nama).to.be.a('string').and.not.empty;",
              "    });",
              "})();",
              "",
              "// ─── TC-08 : Validate 'nik' is 16 digits ─────────────────────────────────────",
              "(() => {",
              "    const nik = requestBodyData.nik;",
              "    pm.test(`TC-08 | Field 'nik' pada request tepat 16 digit | Nilai: \"${nik}\"`, function () {",
              "        pm.expect(nik).to.match(/^\\d{16}$/, `NIK harus 16 digit, ditemukan: \"${nik}\"`);",
              "    });",
              "})();",
              "",
              "// ─── TC-09 : Validate 'kodepoli' is a non-empty string ───────────────────────",
              "(() => {",
              "    const kodepoli = requestBodyData.kodepoli;",
              "    pm.test(`TC-09 | Field 'kodepoli' pada request adalah string tidak kosong | Nilai: \"${kodepoli}\"`, function () {",
              "        pm.expect(kodepoli).to.be.a('string').and.not.empty;",
              "    });",
              "})();",
              "",
              "// ─── TC-10 : Validate 'tanggalperiksa' format is YYYY-MM-DD ──────────────────",
              "(() => {",
              "    const tanggal = requestBodyData.tanggalperiksa;",
              "    pm.test(`TC-10 | Field 'tanggalperiksa' sesuai format YYYY-MM-DD | Nilai: \"${tanggal}\"`, function () {",
              "        pm.expect(tanggal).to.match(/^\\d{4}-\\d{2}-\\d{2}$/, `Format yang diharapkan YYYY-MM-DD, ditemukan: \"${tanggal}\"`);",
              "    });",
              "})();",
              "",
              "// ─── TC-11 : Validate 'tanggalperiksa' is a valid calendar date ──────────────",
              "(() => {",
              "    const tanggal = requestBodyData.tanggalperiksa;",
              "    pm.test(`TC-11 | Field 'tanggalperiksa' adalah tanggal kalender yang valid | Nilai: \"${tanggal}\"`, function () {",
              "        const d = new Date(tanggal);",
              "        pm.expect(isNaN(d.getTime())).to.be.false;",
              "    });",
              "})();",
              "",
              "// ─── TC-12 : Validate 'asuransi' field is present and a string ───────────────",
              "(() => {",
              "    const asuransi = requestBodyData.asuransi;",
              "    pm.test(`TC-12 | Field 'asuransi' ada dan bertipe string | Nilai: \"${asuransi}\"`, function () {",
              "        pm.expect(asuransi).to.be.a('string');",
              "    });",
              "})();",
              "",
              "// ─── TC-13 : Validate 'no_asuransi' field is present ────────────────────────",
              "(() => {",
              "    const noAsuransi = requestBodyData.no_asuransi;",
              "    pm.test(`TC-13 | Field 'no_asuransi' ada pada request (boleh kosong) | Nilai: \"${noAsuransi}\"`, function () {",
              "        pm.expect(requestBodyData).to.have.property('no_asuransi');",
              "    });",
              "})();",
              "",
              "// ─── TC-14 : 401 Unauthorized — invalid token scenario ───────────────────────",
              "(() => {",
              "    const code    = responseJson.header && responseJson.header.code;",
              "    const message = (responseJson.header && responseJson.header.message) || '';",
              "    pm.test(`TC-14 | Jika 401: header.code = 401 dan pesan menunjukkan token tidak valid | Kode aktual: ${code} | Pesan aktual: \"${message}\"`, function () {",
              "        if (pm.response.code === 401) {",
              "            pm.expect(code).to.eql(401);",
              "            pm.expect(message.toLowerCase()).to.satisfy(",
              "                (msg) => msg.includes('tidak valid') || msg.includes('invalid') || msg.includes('unauthorized'),",
              "                `Pesan token tidak valid diharapkan, ditemukan: \"${message}\"`",
              "            );",
              "        } else {",
              "            pm.expect(pm.response.code).to.not.eql(401);",
              "        }",
              "    });",
              "})();",
              "",
              "// ─── TC-15 : kuota_harian and total_hit are numbers ──────────────────────────",
              "(() => {",
              "    const totalHit    = responseJson.header && responseJson.header.total_hit;",
              "    const kuotaHarian = responseJson.header && responseJson.header.kuota_harian;",
              "    pm.test(`TC-15 | header.total_hit bertipe number | Aktual: ${totalHit}`, function () {",
              "        pm.expect(totalHit).to.be.a('number');",
              "    });",
              "    pm.test(`TC-15b | header.kuota_harian bertipe number | Aktual: ${kuotaHarian}`, function () {",
              "        pm.expect(kuotaHarian).to.be.a('number');",
              "    });",
              "})();",
              "",
              "// ─── TC-16 : No unexpected 5xx server error ───────────────────────────────────",
              "(() => {",
              "    pm.test(`TC-16 | Response bukan error server 5xx | Status aktual: ${pm.response.code}`, function () {",
              "        pm.expect(pm.response.code).to.be.below(500);",
              "    });",
              "})();",
              "",
              "// ─── TC-17 : Response has no null header object ───────────────────────────────",
              "(() => {",
              "    pm.test(`TC-17 | Object 'header' pada response tidak null`, function () {",
              "        pm.expect(responseJson.header).to.not.be.null;",
              "    });",
              "})();",
              "",
              "// ─── TC-18 s/d TC-23 : Validasi field wajib request body tidak ditemukan (not found) ──",
              "(() => {",
              "    const requiredFields = [",
              "        { key: 'nama',          label: 'nama' },",
              "        { key: 'nik',           label: 'nik' },",
              "        { key: 'asuransi',      label: 'asuransi' },",
              "        { key: 'no_asuransi',   label: 'no_asuransi' },",
              "        { key: 'kodepoli',      label: 'kodepoli' },",
              "        { key: 'tanggalperiksa',label: 'tanggalperiksa' },",
              "    ];",
              "",
              "    const tcStart = 18;",
              "",
              "    requiredFields.forEach((field, index) => {",
              "        const tcNumber = `TC-${String(tcStart + index).padStart(2, '0')}`;",
              "        const value    = requestBodyData[field.key];",
              "        const isFound  = value !== undefined && value !== null;",
              "",
              "        pm.test(`${tcNumber} | Field '${field.label}' ditemukan pada request body | Nilai: \"${value}\"`, function () {",
              "            pm.expect(requestBodyData).to.have.property(field.key);",
              "            pm.expect(isFound, `Field '${field.label}' tidak ditemukan atau bernilai null/undefined`).to.be.true;",
              "        });",
              "    });",
              "})();"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-username",
            "value": "xxxxxxx",
            "type": "text"
          },
          {
            "key": "x-token",
            "value": "xxxxxxx",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nama\": \"APRIS SUNDIANA\",\n  \"nik\": \"3211111111111111\",\n  \"asuransi\": \"0000\",\n  \"no_asuransi\": \"\",\n  \"kodepoli\": \"UMUM\",\n  \"tanggalperiksa\": \"2022-07-12\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://api.infokes.id/v1/postPendaftaran",
          "protocol": "https",
          "host": [
            "api",
            "infokes",
            "id"
          ],
          "path": [
            "v1",
            "postPendaftaran"
          ]
        }
      },
      "response": []
    }
  ]
}